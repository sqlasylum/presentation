# Sample pgBackRest configuration
# Copy this file to /etc/pgbackrest/pgbackrest.conf (or /etc/pgbackrest.conf)
# and update values for your environment.

[global]
repo1-path=/mnt/data/backups/pgbackrest
repo1-retention-full=7
repo1-retention-diff=14
start-fast=y
process-max=2
log-level-console=info

[main]
pg1-path=/var/lib/postgresql/data
pg1-port=5432
# Optional if running backup from another host:
# pg1-host=127.0.0.1
# pg1-user=postgres
